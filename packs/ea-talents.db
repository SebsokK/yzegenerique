{"_id":"EATAcr01ea","name":"Acrobatics","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Master of movement in confined spaces.","description":"<p>+2 to Mobility when moving through a Cluttered or Cramped zone, or performing a controlled jump.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATAna01ea","name":"Analytical","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Logic over instinct — read people with your mind.","description":"<p>Roll Manipulation using Wits instead of Empathy when detecting lies or sensing emotions.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATAss01ea","name":"Assassin","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Close the distance before they know you're there.","description":"<p>When attempting a sneak attack, no -2 modifier when moving to Engaged range.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATBod01ea","name":"Bodyguard","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Take the hit so they don't have to.","description":"<p>When someone within Short range is hit, roll Mobility to take the hit instead. You can push the roll.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATCal01ea","name":"Calming Presence","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Your presence alone steadies shattered nerves.","description":"<p>Once per Turn, reduce another character's Stress Level by one within Short range. Must be in a safe place. Cannot use on yourself.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATCom01ea","name":"Compassion","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Push beyond your limits when others need you most.","description":"<p>Push any skill roll based on Empathy twice, not just once.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATCre01ea","name":"Creative","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"You find solutions where others see only walls.","description":"<p>Once per session, automatically pass one Observation roll. GM has final say.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATDod01ea","name":"Dodge","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Roll out of the way — even from Horrors.","description":"<p>When attacked in close combat, dodge using Mobility instead of Close Combat. Can reduce damage only. Works against creatures.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATDri01ea","name":"Driver","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Pedal to the metal, whatever the machine.","description":"<p>+2 to Mobility when driving a vehicle (not Automata — use Pilot for that).</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATFas01ea","name":"Fast Reflexes","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Always first to act when it all goes wrong.","description":"<p>Draw two initiative cards instead of one. Choose the one you want to use.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATFie01ea","name":"Field Surgeon","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Steady hands between life and death.","description":"<p>+1 to Medical when treating someone about to die from a critical injury.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATFly01ea","name":"Flyweight","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Speed and agility beat raw power.","description":"<p>When blocking in close combat, use Agility instead of Strength.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATGiv01ea","name":"Give Orders","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Your words become momentum in battle.","description":"<p>As a Slow Action in combat, roll Command. For every success, allies who follow your orders get +1 to their roll.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATGra01ea","name":"Grappler","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Once you have them, they're not going anywhere.","description":"<p>+2 to Close Combat rolls made to grapple a target.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATGut01ea","name":"Gut Feeling","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Something's wrong — you feel it before you see it.","description":"<p>Roll Observation using Empathy instead of Wits to detect an approaching threat.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATHar01ea","name":"Hardened","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Your mind has seen too much to break easily.","description":"<p>Maximum Stability increased by 1. Can be taken up to three times.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATIns01ea","name":"Inquisitive","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Push your mind further than others dare.","description":"<p>Push any skill roll based on Wits twice, not just once.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATKil01ea","name":"Killer","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"You know exactly where to strike.","description":"<p>When an enemy sustains a critical injury, roll twice and choose the result you want.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATLog01ea","name":"Logical","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"A well-reasoned argument beats charm every time.","description":"<p>Roll Command using Wits instead of Empathy when convincing someone to see your point of view.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATLuc01ea","name":"Lucky","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Somehow, you always walk away.","description":"<p>When you suffer a critical injury, re-roll the dice and choose the result you prefer.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATMar01ea","name":"Martial Artist","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Precision and speed over brute force.","description":"<p>When making an armed attack in close combat, use Agility instead of Strength.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATMen01ea","name":"Menacing","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Your presence is enough of a threat.","description":"<p>Roll Command using Strength instead of Empathy when threatening someone.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATRapR01ea","name":"Rapid Reload","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Empty and loaded before they notice.","description":"<p>Reload a weapon as a fast action instead of a slow action.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATReck01ea","name":"Reckless","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Impulsiveness can be a weapon too.","description":"<p>Push any skill roll based on Agility twice, not just once.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATSea01ea","name":"Seduction","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"You are adept at using charm and allure to influence others.","description":"<p>+2 to Manipulation when using flirtatious and seductive techniques to achieve your goal.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATSec01ea","name":"Second Wind","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Not dead yet — roll to prove it.","description":"<p>When broken, roll Endurance to regain Health. Cannot push. Once per broken state.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATSke01ea","name":"Skeptic","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"You are less likely to be fooled by those in power.","description":"<p>+2 to Observation when interacting with the rich, powerful, or those pretending to be such.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATSni01ea","name":"Sniper","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"One shot, one kill — from where they can't see you.","description":"<p>+1 to Ranged Combat when firing a single shot at Long range or more from a hidden position.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATStB01ea","name":"Stop Berserk","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"A word from you can cut through the chaos.","description":"<p>As a Fast Action, yell at someone to snap out of their Berserk. On a successful Command roll, they don't need to roll Pilot against their Berserk this turn.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATStP01ea","name":"Stop Panic","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"You can pull someone back from the edge.","description":"<p>When another character makes a Panic Roll and loses control, make a Command roll to return them to their senses.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATSte01ea","name":"Steady Hands","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Calm under fire, even in the worst circumstances.","description":"<p>Ignore penalties from Conditions when making Ranged Combat rolls.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATSth01ea","name":"Stealthy","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"You can move unseen and unheard.","description":"<p>Ignore penalties from Conditions when making Mobility stealth rolls.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATSto01ea","name":"Stoic","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"You use your mental resilience to withstand physical challenges.","description":"<p>Roll Endurance using Wits instead of Strength.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATTec01ea","name":"Technician","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Your technical expertise makes it easy for you to fix things.","description":"<p>+1 to Machinery when repairing objects or machines, including Automatas.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATTir01ea","name":"Tireless","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"You have exceptional endurance.","description":"<p>+2 to Endurance when resisting the effects of a long march, lack of food, or other strenuous activities.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATTou01ea","name":"Tough","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"You absorb punishment that would floor anyone else.","description":"<p>Maximum Health increased by 2.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATTrG01ea","name":"True Grit","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Sheer determination pushes past your limits.","description":"<p>Push any skill roll based on Strength twice, not just once.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATWat01ea","name":"Watchful","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Eyes in the back of your head.","description":"<p>+2 to Observation when trying to spot a sneak attack or hidden danger.</p>","talentSource":"general","tagIds":[]},"flags":{}}
{"_id":"EATWea01ea","name":"Weapon Specialist","type":"talent","img":"icons/magic/symbols/rune-sigil-red-orange.webp","system":{"excerpt":"Trained to perfection with your weapon of choice.","description":"<p>+1 to rolls with a specific weapon type. Can be chosen multiple times for different types.</p>","talentSource":"general","tagIds":[]},"flags":{}}
