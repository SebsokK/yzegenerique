{"_id":"GhostGen001yze","name":"Ghost","type":"npc","img":"icons/magic/death/ghost-wisp-ice-blue.webp","system":{"health":{"value":5,"max":5,"autoCalc":false},"resolve":{"value":0,"max":0,"autoCalc":false},"specialAttackTableUuid":"","description":"Ghosts are immaterial entities, manifestations of restless spirits that linger in the world of the living. Often bound to specific locations or objects, they can only be harmed by fire or magic. When banished, they return after a day unless their tie to the mortal realm is severed.\n\nArmor Rating: 0 (but see Incorporeal)"},"prototypeToken":{"name":"Ghost","actorLink":false,"disposition":-1,"displayName":20},"items":[{"_id":"GhStr001yzegen","name":"Strength","type":"attribute","img":"icons/svg/d20-grey.svg","system":{"slug":"strength","value":0,"current":0,"category":"Physical","description":"","tagIds":[]},"flags":{}},{"_id":"GhAgi001yzegen","name":"Agility","type":"attribute","img":"icons/svg/d20-grey.svg","system":{"slug":"agility","value":2,"current":2,"category":"Physical","description":"","tagIds":[]},"flags":{}},{"_id":"GhWit001yzegen","name":"Wits","type":"attribute","img":"icons/svg/d20-grey.svg","system":{"slug":"wits","value":3,"current":3,"category":"Mental","description":"","tagIds":[]},"flags":{}},{"_id":"GhEmp001yzegen","name":"Empathy","type":"attribute","img":"icons/svg/d20-grey.svg","system":{"slug":"empathy","value":0,"current":0,"category":"Social","description":"","tagIds":[]},"flags":{}},{"_id":"GhFor001yzegen","name":"Force","type":"skill","img":"icons/svg/d20-grey.svg","system":{"slug":"force","value":1,"linkedAttribute":"strength","description":"","tagIds":[]},"flags":{}},{"_id":"GhMob001yzegen","name":"Mobility","type":"skill","img":"icons/svg/d20-grey.svg","system":{"slug":"mobility","value":3,"linkedAttribute":"agility","description":"","tagIds":[]},"flags":{}},{"_id":"GhSte001yzegen","name":"Stealth","type":"skill","img":"icons/svg/d20-grey.svg","system":{"slug":"stealth","value":2,"linkedAttr