{{!-- templates/item/skill-sheet.hbs --}}
<form class="yze-sheet item-sheet skill-sheet" autocomplete="off">

  <header class="item-header">
    <img class="item-img" src="{{item.img}}" data-edit="img" alt="{{item.name}}" />
    <div class="item-header-fields">
      <input class="item-name-input" type="text" name="name" value="{{item.name}}" />
    </div>
  </header>

  <div class="item-form">
    <div class="form-group">
      <label>Level</label>
      <input type="number" name="system.value" value="{{system.value}}" min="0" max="10" />
    </div>
    <div class="form-group">
      <label>Linked Attribute <span class="form-hint">(slug)</span></label>
      <input type="text" name="system.linkedAttribute" value="{{system.linkedAttribute}}"
        placeholder="e.g. strength" />
    </div>
    <div class="form-group">
      <label>Slug</label>
      <input type="text" name="system.slug" value="{{system.slug}}"
        placeholder="e.g. close-combat" />
    </div>
    <div class="form-group">
      <label>Description</label>
      <input type="text" name="system.description" value="{{system.description}}" />
    </div>
  </div>

</form>
