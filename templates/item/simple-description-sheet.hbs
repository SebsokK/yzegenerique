{{!-- templates/item/simple-description-sheet.hbs --}}
<form class="yze-sheet item-sheet simple-description-sheet" autocomplete="off">
  <header class="item-header">
    <img class="item-img" src="{{item.img}}" data-edit="img" alt="{{item.name}}" />
    <div class="item-header-fields">
      <input class="item-name-input" type="text" name="name" value="{{item.name}}" />
    </div>
  </header>
  <div class="item-body" style="padding:8px;display:flex;flex-direction:column;gap:8px;">
    <div class="form-group" style="display:flex;flex-direction:column;gap:4px;">
      <label style="font-size:0.75em;text-transform:uppercase;color:var(--yze-color-text-muted);">Description</label>
      <textarea name="system.description" rows="7"
        style="background:var(--yze-color-bg);border:1px solid var(--yze-color-border);
               border-radius:var(--yze-radius);padding:8px;color:var(--yze-color-text);
               resize:vertical;font-family:var(--yze-font-body);font-size:0.9em;line-height:1.5;">{{system.description}}</textarea>
    </div>
  </div>
</form>
