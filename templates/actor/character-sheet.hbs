{{!-- templates/actor/character-sheet.hbs --}}
<form class="yze-sheet character-sheet" autocomplete="off">

  {{!-- ═══ HEADER ═══ --}}
  <header class="sheet-header">
    <img class="actor-portrait" src="{{actor.img}}" data-edit="img" alt="{{actor.name}}" />
    <div class="header-center">
      <input class="header-name" type="text" name="name" value="{{actor.name}}" />
      <input class="header-archetype" type="text" name="system.archetype"
        value="{{system.archetype}}" placeholder="{{localize 'YZE.Archetype'}}" />
      <div class="header-xp">
        <label class="header-xp-label">{{localize "YZE.XP"}}</label>
        <div class="header-xp-pips">
          {{#each xpPips as |pip|}}
          <button type="button" class="xp-pip {{#if pip.filled}}xp-pip--filled{{/if}}"
            data-xp-index="{{pip.index}}"></button>
          {{/each}}
        </div>
      </div>
    </div>
    <div class="header-resources">
      {{#if system.health}}
      <div class="hdr-resource">
        <label>{{localize "YZE.Health"}}</label>
        <div class="hdr-tracker-wrap">
          <div class="hdr-tracker" data-value="{{system.health.value}}" data-max="{{system.health.max}}">
            <div class="hdr-tracker-bar"></div>
          </div>
          <div class="hdr-resource-inputs">
            <input type="number" name="system.health.value"
              value="{{system.health.value}}" min="0" max="{{system.health.max}}" />
            <span>/</span>
            <input type="number" name="system.health.max"
              value="{{system.health.max}}" min="0"
              {{#unless system.health.autoCalc}}class="hdr-manual"{{/unless}} />
            <button type="button" class="hdr-lock-btn"
              data-action="toggleAutoCalc" data-field="system.health.autoCalc"
              title="{{#if system.health.autoCalc}}Auto-calculated (click to override){{else}}Manual override (click to restore auto){{/if}}">
              {{#if system.health.autoCalc}}🔒{{else}}✏️{{/if}}
            </button>
          </div>
        </div>
      </div>
      {{/if}}
      {{#if system.resolve}}
      <div class="hdr-resource">
        <label>{{localize "YZE.Resolve"}}</label>
        <div class="hdr-tracker-wrap">
          <div class="hdr-tracker" data-value="{{system.resolve.value}}" data-max="{{system.resolve.max}}">
            <div class="hdr-tracker-bar"></div>
          </div>
          <div class="hdr-resource-inputs">
            <input type="number" name="system.resolve.value"
              value="{{system.resolve.value}}" min="0" max="{{system.resolve.max}}" />
            <span>/</span>
            <input type="number" name="system.resolve.max"
              value="{{system.resolve.max}}" min="0"
              {{#unless system.resolve.autoCalc}}class="hdr-manual"{{/unless}} />
            <button type="button" class="hdr-lock-btn"
              data-action="toggleAutoCalc" data-field="system.resolve.autoCalc"
              title="{{#if system.resolve.autoCalc}}Auto-calculated (click to override){{else}}Manual override (click to restore auto){{/if}}">
              {{#if system.resolve.autoCalc}}🔒{{else}}✏️{{/if}}
            </button>
          </div>
        </div>
      </div>
      {{/if}}
      {{#if enableStress}}
      <div class="hdr-resource hdr-stress">
        <label>{{localize "YZE.Stress"}}</label>
        <input type="number" name="system.stress.value"
          value="{{system.stress.value}}" min="0" />
      </div>
      {{/if}}
    </div>
  </header>

  {{!-- ═══ ONGLETS ═══ --}}
  <nav class="sheet-tabs">
    <button type="button" class="tab-btn active" data-tab="character">Character</button>
    <button type="button" class="tab-btn" data-tab="combat">Combat</button>
    <button type="button" class="tab-btn" data-tab="bio">Bio</button>
  </nav>

  {{!-- ═══ ONGLET CHARACTER ═══ --}}
  <div class="tab-panel active" data-panel="character">

    {{!-- Ressources configurables --}}
    {{#if resources.length}}
    <section class="sheet-section hoverable-section">
      <h2 class="section-title">{{localize "YZE.Resources"}}</h2>
      {{#each resources as |res|}}
      <div class="resource-row hoverable-row" data-item-id="{{res.id}}">
        <span class="resource-name">{{res.name}}</span>
        <input type="number" data-item-id="{{res.id}}" data-field="system.value"
          value="{{res.system.value}}" min="{{res.system.min}}" max="{{res.system.max}}" />
        <span>/</span><span>{{res.system.max}}</span>
        <span class="row-actions">
          <button type="button" class="ea-icon-btn" data-action="itemEdit" data-item-id="{{res.id}}">✎</button>
          <button type="button" class="ea-icon-btn ea-delete-btn" data-action="itemDelete" data-item-id="{{res.id}}">✕</button>
        </span>
      </div>
      {{/each}}
      <div class="section-add-row">
        <button type="button" class="sheet-add-btn" data-action="itemCreate" data-type="resource">+ {{localize "YZE.AddResource"}}</button>
      </div>
    </section>
    {{else}}
    <div class="hoverable-section section-add-row-standalone">
      <button type="button" class="sheet-add-btn" data-action="itemCreate" data-type="resource">+ {{localize "YZE.AddResource"}}</button>
    </div>
    {{/if}}

    {{!-- Attributs --}}
    <section class="sheet-section hoverable-section attributes-section">
      <h2 class="section-title">{{localize "YZE.Attributes"}}</h2>
      <div class="attributes-row">
        {{#each attributes as |attr|}}
        <div class="attr-block hoverable-row {{#if attr.ciMod}}ci-penalized{{/if}}" data-item-id="{{attr.id}}">
          <button type="button" class="attr-name rollable" data-action="rollAttribute" data-attr-id="{{attr.id}}" title="Roll {{attr.name}}">{{attr.name}}</button>
          <div class="attr-val-wrapper">
            <input class="attr-val" type="number"
              data-item-id="{{attr.id}}" data-field="system.value"
              value="{{attr.system.value}}" min="1" max="5" />
            {{#if attr.ciMod}}<span class="ci-mod-badge">{{attr.ciMod}}</span>{{/if}}
          </div>
          <div class="yze-attr-pips">
            {{#each attr.pips as |pip|}}
            <button class="yze-pip {{#if pip.filled}}yze-pip--filled{{/if}}"
              type="button"
              data-item-id="{{pip.attrId}}"
              data-pip-index="{{pip.index}}"></button>
            {{/each}}
          </div>
          <span class="row-actions">
            <button class="ea-icon-btn" type="button" data-action="itemEdit" data-item-id="{{attr.id}}">✎</button>
            <button class="ea-icon-btn ea-delete-btn" type="button" data-action="itemDelete" data-item-id="{{attr.id}}">✕</button>
          </span>
        </div>
        {{else}}
        <p class="empty-hint">{{localize "YZE.NoAttributes"}}</p>
        {{/each}}
      </div>
      <div class="section-add-row">
        <button type="button" class="sheet-add-btn" data-action="itemCreate" data-type="attribute">+ {{localize "YZE.AddAttribute"}}</button>
      </div>
    </section>

    {{!-- Skills --}}
    <section class="sheet-section hoverable-section skills-section">
      <h2 class="section-title">{{localize "YZE.Skills"}}</h2>
      <div class="skills-grid">
        {{#each skills as |skill|}}
        <div class="skill-row hoverable-row {{#if skill.ciMod}}ci-penalized{{/if}}" data-item-id="{{skill.id}}">
          <button type="button" class="skill-name rollable" data-action="rollSkill" data-item-id="{{skill.id}}" title="Roll {{skill.name}}">{{skill.name}}</button>
          <span class="skill-attr">{{skill.system.linkedAttribute}}</span>
          <div class="skill-val-wrapper">
            <input class="skill-val" type="number"
              data-item-id="{{skill.id}}" data-field="system.value"
              value="{{skill.baseVal}}" min="0" max="6" />
            {{#if skill.ciMod}}<span class="ci-mod-badge">{{skill.ciMod}}</span>{{/if}}
          </div>
          <span class="row-actions">
            <button class="ea-icon-btn" type="button" data-action="itemEdit" data-item-id="{{skill.id}}">✎</button>
            <button class="ea-icon-btn ea-delete-btn" type="button" data-action="itemDelete" data-item-id="{{skill.id}}">✕</button>
          </span>
        </div>
        {{else}}
        <p class="empty-hint">{{localize "YZE.NoSkills"}}</p>
        {{/each}}
      </div>
      <div class="section-add-row">
        <button type="button" class="sheet-add-btn" data-action="itemCreate" data-type="skill">+ {{localize "YZE.AddSkill"}}</button>
      </div>
    </section>

    {{!-- Talents --}}
    <section class="sheet-section hoverable-section">
      <h2 class="section-title">{{localize "YZE.Talents"}}</h2>
      {{#if talents.length}}
      <div class="ea-gear-list">
        {{#each talents as |talent|}}
        <div class="ea-gear-row hoverable-row" data-item-id="{{talent.id}}">
          <span class="ea-gear-name">{{talent.name}}</span>
          {{#if talent.system.excerpt}}
          <span class="talent-excerpt">{{talent.system.excerpt}}</span>
          {{/if}}
          <span class="row-actions">
            <button class="ea-icon-btn" type="button" data-action="itemEdit" data-item-id="{{talent.id}}">✎</button>
            <button class="ea-icon-btn ea-delete-btn" type="button" data-action="itemDelete" data-item-id="{{talent.id}}">✕</button>
          </span>
        </div>
        {{/each}}
      </div>
      {{else}}<p class="empty-hint">{{localize "YZE.NoTalents"}}</p>{{/if}}
      <div class="section-add-row">
        <button type="button" class="sheet-add-btn" data-action="itemCreate" data-type="talent">+ {{localize "YZE.AddTalent"}}</button>
      </div>
    </section>

  </div>

  {{!-- ═══ ONGLET COMBAT ═══ --}}
  <div class="tab-panel" data-panel="combat">

    <section class="sheet-section hoverable-section">
      <h2 class="section-title">⚔ {{localize "YZE.Weapons"}}</h2>
      {{#if weapons.length}}
      <div class="ea-gear-list">
        {{#each weapons as |item|}}
        <div class="ea-weapon-card" data-item-id="{{item.id}}">
          <div class="ea-gear-row hoverable-row ea-weapon-main" data-item-id="{{item.id}}">
            <button type="button" class="ea-gear-name rollable" data-action="rollWeapon" data-item-id="{{item.id}}" title="Roll {{item.name}}">{{item.name}}</button>
            <span class="ea-gear-stat">{{item.system.grip}}</span>
            <span class="ea-gear-stat">DMG {{item.system.damage}}</span>
            <span class="ea-range ea-gear-stat">{{item.system.range}}</span>
            {{#if item.system.bonusDice}}<span class="ea-gear-bonus">+{{item.system.bonusDice}}d</span>{{/if}}
            <span class="row-actions">
              <button class="ea-icon-btn" type="button" data-action="itemEdit" data-item-id="{{item.id}}">✎</button>
              <button class="ea-icon-btn ea-delete-btn" type="button" data-action="itemDelete" data-item-id="{{item.id}}">✕</button>
            </span>
          </div>
          {{#if item.resolvedTags.length}}
          <div class="weapon-tags-row">
            {{#each item.resolvedTags as |tag|}}
            <span class="yze-weapon-tag" {{#if tag.tooltip}}title="{{tag.tooltip}}"{{/if}}>{{tag.name}}</span>
            {{/each}}
          </div>
          {{/if}}
          {{#if item.system.isRanged}}
          <div class="ea-weapon-reloads {{#if item.system.isOutOfAmmo}}ea-out-of-ammo{{/if}}" data-item-id="{{item.id}}">
            <input type="number" data-item-id="{{item.id}}" data-field="system.currentReloads"
              value="{{item.system.currentReloads}}" min="0" max="{{item.system.maxReloads}}" />
            <span class="ea-sep">/</span>
            <span class="ea-max">{{item.system.maxReloads}}</span>
            <button class="ea-reload-btn" type="button"
              data-action="reloadWeapon" data-item-id="{{item.id}}">Reload</button>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}<p class="empty-hint">{{localize "YZE.NoWeapons"}}</p>{{/if}}
      <div class="section-add-row">
        <button type="button" class="sheet-add-btn" data-action="itemCreate" data-type="weapon">+ {{localize "YZE.AddWeapon"}}</button>
      </div>
    </section>

    <section class="sheet-section hoverable-section">
      <h2 class="section-title">🛡 {{localize "YZE.Armors"}}</h2>
      {{#if armors.length}}
      <div class="ea-gear-list">
        {{#each armors as |item|}}
        <div class="ea-gear-row hoverable-row {{#if item.system.isDestroyed}}ea-armor--destroyed{{/if}}" data-item-id="{{item.id}}">
          <button type="button" class="ea-gear-name rollable" data-action="rollArmor" data-item-id="{{item.id}}" title="Roll {{item.name}}" {{#if item.system.isDestroyed}}disabled{{/if}}>{{item.name}}</button>
          <span class="ea-gear-ar">AR {{item.system.armorRating}}/{{item.system.armorRatingMax}}</span>
          <span class="row-actions">
            <button class="ea-icon-btn" type="button" data-action="itemEdit" data-item-id="{{item.id}}">✎</button>
            <button class="ea-icon-btn ea-delete-btn" type="button" data-action="itemDelete" data-item-id="{{item.id}}">✕</button>
          </span>
        </div>
        {{/each}}
      </div>
      {{else}}<p class="empty-hint">{{localize "YZE.NoArmors"}}</p>{{/if}}
      <div class="section-add-row">
        <button type="button" class="sheet-add-btn" data-action="itemCreate" data-type="armor">+ {{localize "YZE.AddArmor"}}</button>
      </div>
    </section>

    {{!-- Blessures Critiques --}}
    <section class="sheet-section hoverable-section ci-section">
      <h2 class="section-title">🩸 {{localize "YZE.CriticalInjuries"}}</h2>
      {{#if criticalInjuries.length}}
      <div class="ci-list">
        {{#each criticalInjuries as |ci|}}
        <div class="ci-card {{#if ci.system.healed}}ci-card--healed{{/if}} {{#if ci.system.lethal}}ci-card--lethal{{/if}} hoverable-row"
             data-item-id="{{ci.id}}">
          <div class="ci-card-header">
            <span class="ci-name">{{ci.name}}</span>
            {{#if ci.system.lethal}}<span class="ci-lethal-tag">⚠ LETHAL</span>{{/if}}
            {{#if ci.system.instantDeath}}<span class="ci-death-tag">💀 INSTANT DEATH</span>{{/if}}
            {{#if ci.system.healed}}<span class="ci-healed-tag">✓ Healed</span>{{/if}}
            <span class="row-actions">
              <button class="ea-icon-btn" type="button" data-action="itemEdit" data-item-id="{{ci.id}}">✎</button>
              <button class="ea-icon-btn ea-delete-btn" type="button" data-action="itemDelete" data-item-id="{{ci.id}}">✕</button>
            </span>
          </div>
          {{#if ci.system.effect}}
          <div class="ci-effect">{{ci.system.effect}}</div>
          {{/if}}
          <div class="ci-footer">
            {{#if ci.system.timeLimit}}<span class="ci-meta">⏱ {{ci.system.timeLimit}}</span>{{/if}}
            {{#if ci.system.healingTime}}
            <span class="ci-meta">🩹
              {{#if ci.isRollableHealingTime}}
              <button type="button" class="ci-roll-healing-btn"
                data-action="rollCiHealing"
                data-item-id="{{ci.id}}"
                title="Click to roll healing time">{{ci.system.healingTime}} {{#unless ci.system.timeLimit}}Days{{/unless}}</button>
              {{else}}
              {{ci.system.healingTime}}
              {{/if}}
            </span>
            {{/if}}
            <label class="ci-healed-check">
              <input type="checkbox" data-item-id="{{ci.id}}" data-field="system.healed"
                {{#if ci.system.healed}}checked{{/if}} />
              Healed
            </label>
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}<p class="empty-hint">{{localize "YZE.NoCriticalInjuries"}}</p>{{/if}}
      <div class="section-add-row">
        <button type="button" class="sheet-add-btn" data-action="itemCreate" data-type="critical-injury">+ {{localize "YZE.AddCriticalInjury"}}</button>
      </div>
    </section>

    <section class="sheet-section hoverable-section">
      <h2 class="section-title">{{localize "YZE.Gear"}}</h2>
      {{#if gear.length}}
      <div class="ea-gear-list">
        {{#each gear as |item|}}
        <div class="ea-gear-row hoverable-row" data-item-id="{{item.id}}">
          <span class="ea-gear-name" {{#if item.tooltip}}title="{{item.tooltip}}"{{/if}}>{{item.name}}</span>
          <span class="row-actions">
            <button class="ea-icon-btn" type="button" data-action="itemEdit" data-item-id="{{item.id}}">✎</button>
            <button class="ea-icon-btn ea-delete-btn" type="button" data-action="itemDelete" data-item-id="{{item.id}}">✕</button>
          </span>
        </div>
        {{/each}}
      </div>
      {{else}}<p class="empty-hint">{{localize "YZE.NoGear"}}</p>{{/if}}
      <div class="section-add-row">
        <button type="button" class="sheet-add-btn" data-action="itemCreate" data-type="gear">+ {{localize "YZE.AddGear"}}</button>
      </div>
    </section>

  </div>

  {{!-- ═══ ONGLET BIO ═══ --}}
  <div class="tab-panel" data-panel="bio">
    <section class="sheet-section biography-section">
      <h2 class="section-title">{{localize "YZE.Biography"}}</h2>
      {{editor enriched.biography target="system.biography" button=true engine="prosemirror" collaborate=false editable=editable}}
    </section>
  </div>

</form>
